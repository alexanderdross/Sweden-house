# ----------------------------------------------------------------------------
# Sweden House — environment variables
# Copy this file to ".env.local" for local development, and add the same
# variables in the Vercel dashboard (Project → Settings → Environment Variables)
# for production. The site builds and runs even if these are empty; the booking
# form will simply report that email delivery is not configured yet.
# ----------------------------------------------------------------------------

# --- SMTP (outgoing booking emails) ----------------------------------------
# Use any SMTP provider / mailbox. Examples:
#   Gmail:   host=smtp.gmail.com   port=465  (use an App Password, not your login)
#   iCloud:  host=smtp.mail.me.com port=587  (use an app-specific password)
#   Custom:  your hosting provider's SMTP settings
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Address shown in the "From" field of outgoing emails (often same as SMTP_USER).
SMTP_FROM="Sweden House <bookings@example.com>"

# Where booking requests are delivered (the owner's inbox).
BOOKING_RECIPIENT=owner@example.com

# --- Airbnb calendar sync (optional) ---------------------------------------
# One-way sync: paste the Airbnb iCal export URL so dates already booked on
# Airbnb are blocked on this site too.
# Get it from: Airbnb → Listing → Calendar → Availability → "Connect calendars"
#   → "Export calendar" → copy the .ics link.
AIRBNB_ICAL_URL=

# --- Public site URL (used for SEO / hreflang / canonical) ------------------
# e.g. https://sweden-house.vercel.app  (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
